{
  "name": "@hr-saas/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --exclude='**/*.integration.test.ts'",
    "test:integration": "vitest run --passWithNoTests --include='**/*.integration.test.ts'"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@hr-saas/contracts": "workspace:*",
    "@hr-saas/db": "workspace:*",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5",
    "fastify-type-provider-zod": "^4.0.2",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.8.6",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.13.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.13.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
