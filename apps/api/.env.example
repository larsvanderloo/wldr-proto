# ---------------------------------------------------------------------------
# HR SaaS API — omgevingsvariabelen
# Kopieer naar .env en vul in. Commit .env NOOIT naar git.
# ---------------------------------------------------------------------------

# Server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# CORS — komma-separated lijst van toegestane web-origins.
# Wildcard (*) is verboden (incompatibel met credentials: true).
# Lokaal:
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Productie (Vercel + Fly):
# CORS_ALLOWED_ORIGINS=https://app.larsvdloo.com

# Database (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hr_saas_dev

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Auth — JWT + cookie-sessies (FEAT-0002)
# JWT_SECRET en COOKIE_SECRET zijn 32-byte hex strings.
# Genereer elke waarde afzonderlijk: openssl rand -hex 32
# Gebruik NOOIT dezelfde waarde voor beide.
# In productie/staging: ingesteld als Fly.io secret + GitHub Actions secret.
# Commit deze waarden NOOIT naar git.
JWT_SECRET=
COOKIE_SECRET=

# Encryptie-sleutel voor PII op kolomniveau (pgcrypto / KMS)
# Genereer met: openssl rand -hex 32
# ENCRYPTION_KEY=
