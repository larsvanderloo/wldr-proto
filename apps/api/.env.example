# ---------------------------------------------------------------------------
# DEPRECATED — Sprint 2.5 (INFRA-0021)
# De standalone Fastify API (apps/api/) is niet meer in gebruik als
# zelfstandige service. API-logica is gemigreerd naar Nuxt Nitro server-routes
# in apps/web/server/. Dit bestand blijft aanwezig voor referentie tijdens de
# transitie en wordt verwijderd in INFRA-0024 zodra de pivot stable is.
# ---------------------------------------------------------------------------
# HR SaaS API — omgevingsvariabelen (historisch)
# Kopieer naar .env en vul in. Commit .env NOOIT naar git.
# ---------------------------------------------------------------------------

# Server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# CORS — komma-separated lijst van toegestane web-origins.
# Wildcard (*) is verboden (incompatibel met credentials: true).
# Lokaal:
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Productie (Vercel + Fly):
# CORS_ALLOWED_ORIGINS=https://app.larsvdloo.com

# Database (Postgres)
DATABASE_URL=postgresql://hrsaas:hrsaas@localhost:5432/hrsaas
# Directe (unpooled) verbinding voor migraties + seeds (ADR-0005)
DIRECT_URL=postgresql://hrsaas:hrsaas@localhost:5432/hrsaas

# JWT — HS256 access-token signing key
# Genereer met: openssl rand -hex 64
# Productie (Nitro/Vercel): Vercel env-var, gesynchroniseerd via vercel-env-sync job
# (Fly.io niet meer in gebruik — INFRA-0021)
JWT_SECRET=dev-only-jwt-key-change-in-production

# Cookie signing secret (@fastify/cookie)
# Genereer met: openssl rand -hex 32
# Productie (Nitro/Vercel): Vercel env-var, gesynchroniseerd via vercel-env-sync job
# (Fly.io niet meer in gebruik — INFRA-0021)
COOKIE_SECRET=dev-only-cookie-secret-change-in-production

# Encryptie-sleutel voor PII op kolomniveau (pgcrypto / KMS)
# Genereer met: openssl rand -hex 32
# Productie (Nitro/Vercel): Vercel env-var, gesynchroniseerd via vercel-env-sync job
# (Fly.io niet meer in gebruik — INFRA-0021)
PII_ENCRYPTION_KEY=dev-only-pii-key-change-in-production
